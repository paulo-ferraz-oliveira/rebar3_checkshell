{minimum_otp_vsn, "28"}.

{erl_opts, [
    debug_info,
    report,
    verbose,
    warnings_as_errors
]}.

{project_plugins, [
    {erlfmt, "1.8.0"},
    {rebar3_ex_doc, "0.2.31"},
    {rebar3_hank, "1.6.1"},
    {rebar3_hex, "7.1.0"},
    {rebar3_lint, "5.0.2"}
]}.

{deps, [{tls_certificate_check, "1.32.1"}]}.

{alias, [
    {ci, [
        {fmt, "--check"},
        compile,
        {plugins, "upgrade --all"},
        hank,
        lint,
        {do, "default as test xref"},
        {do, "default as test dialyzer"},
        ct,
        cover,
        ex_doc
    ]}
]}.

{shell, [{apps, [rebar3_checkshell]}]}.

{erlfmt, [
    write,
    {files, [
        "*.config",
        "src/**/*{.app.src,erl}",
        "example/src/*.config",
        "example/src/**/*{.app.src,erl}"
    ]}
]}.

{profiles, [
    {test, [
        {cover_enabled, true},
        {cover_excl_mods, [rebar3_checkshell]},
        {cover_opts, [verbose]},
        {deps, [{meck, "1.1.1"}]},
        {erl_opts, [
            debug_info,
            report,
            verbose,
            nowarn_missing_spec_all,
            warnings_as_errors
        ]},
        {extra_src_dirs, [{"test", [{recursive, true}]}]},
        {xref_extra_paths, ["test"]}
    ]}
]}.

{hex, [{doc, #{provider => ex_doc}}]}.

{ex_doc, [
    {extras, ["README.md"]},
    {main, "README.md"},
    {api_reference, false},
    {source_url, "https://github.com/paulo-ferraz-oliveira/rebar3_checkshell"},
    {prefix_ref_vsn_with_v, false}
]}.

{escript_incl_apps, [rebar]}.

{dialyzer, [
    {warnings, [
        no_unknown
    ]}
]}.
